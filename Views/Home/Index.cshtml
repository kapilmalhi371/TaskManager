@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4">Welcome to TaskManager</h1>
    <p class="lead">Organize your tasks efficiently.</p>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <a asp-controller="Tasks" asp-action="Index" class="btn btn-primary btn-lg">Go to My Tasks</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">Get Started</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Login</a>
    }
</div>